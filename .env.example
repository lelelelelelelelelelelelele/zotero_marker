# Copy to .env and fill in. .env is git-ignored.

# Semantic Scholar API key — https://www.semanticscholar.org/product/api
# Optional: without it the tool still works via DBLP + rate-limited S2 (slower).
S2_API_KEY=

# Zotero local API. Zotero 7+ desktop must be running. (Reads use this; it is read-only.)
ZOTERO_API_BASE=http://localhost:23119/api

# REQUIRED. Your Zotero user/library id — the number shown at
# https://www.zotero.org/settings/keys ("Your userID for use in API calls is ...").
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=users

# REQUIRED ONLY TO WRITE BACK. The local API is read-only, so writing venue metadata
# goes through the Zotero Web API and needs a key with write access:
# https://www.zotero.org/settings/keys . Leave empty for resolve-only (dry-run).
ZOTERO_API_KEY=

# Polite contact string sent to public APIs.
CONTACT_EMAIL=you@example.com
